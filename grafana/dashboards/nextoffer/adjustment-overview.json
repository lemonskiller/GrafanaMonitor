{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["nextoffer", "adjustment", "ai-latency", "vllm"],
  "templating": {
    "list": [
      {
        "name": "intent",
        "label": "意图",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\"}, intent)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\"}, intent)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "provider",
        "label": "供应商",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\"}, provider)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\"}, provider)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "model",
        "label": "应用模型",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\",provider=~\"$provider\"}, model)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\",provider=~\"$provider\"}, model)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "status",
        "label": "状态",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\"}, status)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\"}, status)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "vllm_model",
        "label": "vLLM 模型",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values({__name__=\"vllm:request_success_total\",job=\"vllm\"}, model_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values({__name__=\"vllm:request_success_total\",job=\"vllm\"}, model_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "调整意见耗时",
  "uid": "nextoffer-adjustment-latency",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "首 Token P95",
      "description": "从 NextOffer 接收请求到首个 reasoning 或正文 Token，包含网络、模型排队和 prefill。",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"first_token\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "正文完成 P95",
      "description": "从请求开始到正文流完成的累计耗时。",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"answer_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 30}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 3,
      "title": "快捷建议 P95",
      "description": "后台异步生成三条快捷建议的模型请求耗时。",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"suggestions_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "总耗时 P95",
      "description": "主请求开始到快捷建议完成；不生成建议时到正文完成。",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"conversation_total\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 15}, {"color": "red", "value": 45}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "非重叠阶段平均耗时",
      "description": "直接比较可相加的阶段：流建立、供应商首 Token、推理、正文、建议调度空档和建议生成。最长的条目就是主要瓶颈。",
      "type": "bargauge",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (phase) (rate(nextoffer_ai_phase_duration_seconds_sum{application=\"nextoffer\",phase=~\"stream_open|provider_first_token|reasoning_generation|answer_generation|suggestions_dispatch|suggestions_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])) / clamp_min(sum by (phase) (rate(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",phase=~\"stream_open|provider_first_token|reasoning_generation|answer_generation|suggestions_dispatch|suggestions_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])), 0.000000001)", "legendFormat": "{{phase}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "continuous-GrYlRd"}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto"}
    },
    {
      "id": 6,
      "title": "阶段 P50 / P95 趋势",
      "description": "P50 反映常态，P95 反映慢请求尾部。累计阶段与非重叠阶段都保留，便于看 SLA 和拆分。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, phase) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=~\"stream_open|provider_first_token|first_token|answer_first_token|reasoning_generation|answer_generation|answer_complete|suggestions_dispatch|suggestions_complete|conversation_total\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])))", "legendFormat": "{{phase}} P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, phase) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=~\"stream_open|provider_first_token|first_token|answer_first_token|reasoning_generation|answer_generation|answer_complete|suggestions_dispatch|suggestions_complete|conversation_total\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])))", "legendFormat": "{{phase}} P95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7,
      "title": "按供应商 / 模型 / 阶段平均耗时",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 18, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (provider, model, phase) (rate(nextoffer_ai_phase_duration_seconds_sum{application=\"nextoffer\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])) / clamp_min(sum by (provider, model, phase) (rate(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])), 0.000000001)", "legendFormat": "{{provider}} / {{model}} / {{phase}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8,
      "title": "阶段失败率",
      "description": "按 phase 统计 error 样本占比。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 6, "x": 18, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "100 * sum by (phase) (rate(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",status=\"error\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\"}[$__rate_interval])) / clamp_min(sum by (phase) (rate(nextoffer_ai_phase_duration_seconds_count{application=\"nextoffer\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\"}[$__rate_interval])), 0.000000001)", "legendFormat": "{{phase}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9,
      "title": "vLLM 内部耗时",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "panels": []
    },
    {
      "id": 10,
      "title": "vLLM 请求队列",
      "description": "waiting 持续升高说明主要瓶颈在 vLLM 排队或容量不足。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model_name) ({__name__=\"vllm:num_requests_running\",job=\"vllm\",model_name=~\"$vllm_model\"})", "legendFormat": "{{model_name}} running", "refId": "A"},
        {"expr": "sum by (model_name) ({__name__=\"vllm:num_requests_waiting\",job=\"vllm\",model_name=~\"$vllm_model\"})", "legendFormat": "{{model_name}} waiting", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11,
      "title": "vLLM 排队 / Prefill / Decode P95",
      "description": "queue 高表示容量/调度问题；prefill 高通常与输入上下文长度相关；decode 高表示正文生成慢。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 8, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:request_queue_time_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} queue", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:request_prefill_time_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} prefill", "refId": "B"},
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:request_decode_time_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} decode", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 12,
      "title": "vLLM TTFT / TPOT / E2E P95",
      "description": "TTFT 对应首 Token，TPOT 对应单 Token 生成间隔，E2E 对应模型服务器端总耗时。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:time_to_first_token_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} TTFT", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:time_per_output_token_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))) or histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:request_time_per_output_token_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} TPOT", "refId": "B"},
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:e2e_request_latency_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} E2E", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 13,
      "title": "vLLM Token 吞吐",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model_name) (rate({__name__=\"vllm:prompt_tokens_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))", "legendFormat": "{{model_name}} 输入 token/s", "refId": "A"},
        {"expr": "sum by (model_name) (rate({__name__=\"vllm:generation_tokens_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))", "legendFormat": "{{model_name}} 输出 token/s", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 14,
      "title": "vLLM GPU KV Cache / 抢占",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "avg by (model_name) ({__name__=\"vllm:gpu_cache_usage_perc\",job=\"vllm\",model_name=~\"$vllm_model\"})", "legendFormat": "{{model_name}} KV cache", "refId": "A"},
        {"expr": "sum by (model_name) (rate({__name__=\"vllm:num_preemptions_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))", "legendFormat": "{{model_name}} preemption/s", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    }
  ]
}
