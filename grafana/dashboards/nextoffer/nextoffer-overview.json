    },
    {
      "id": 12,
      "title": "AI 首 Token P95",
      "description": "从后端收到主对话请求到首个 reasoning 或正文 Token。",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"first_token\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 13,
      "title": "AI 正文完成 P95",
      "description": "从主对话请求开始到正文流完成的累计耗时。",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"answer_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 30}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 14,
      "title": "AI 快捷建议 P95",
      "description": "正文完成后，后台异步生成三条快捷建议的请求耗时。",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"suggestions_complete\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 15,
      "title": "AI 总耗时 P95",
      "description": "主对话请求开始到后台快捷建议完成；不生成建议时到正文完成。",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=\"conversation_total\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval]))) or on() vector(0)", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 15}, {"color": "red", "value": 45}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 16,
      "title": "AI 各阶段耗时趋势",
      "description": "P95 趋势。answer_complete 和 conversation_total 是累计指标，其余阶段可用于拆分。",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, phase) (rate(nextoffer_ai_phase_duration_seconds_bucket{application=\"nextoffer\",phase=~\"first_token|answer_generation|answer_complete|suggestions_complete|conversation_total\",intent=~\"$intent\",provider=~\"$provider\",model=~\"$model\",status=~\"$status\"}[$__rate_interval])))", "legendFormat": "{{phase}} P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 3, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "none"}}}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 17,
      "title": "AI 平均耗时占比",
      "description": "非重叠阶段的平均耗时 / 平均总耗时。三项之和未覆盖的部分是正文结束到建议请求之间的浏览器、网络与调度间隔。",
      "type": "bargauge",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
