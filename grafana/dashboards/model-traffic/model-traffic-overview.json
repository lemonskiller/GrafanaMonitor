{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["model-traffic", "ollama", "vllm", "tokens"],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "模型",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(ollama_model_available{job=\"ollama\"}, model)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(ollama_model_available{job=\"ollama\"}, model)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "client_service",
        "label": "调用服务",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values(ollama_requests_total{job=\"ollama\",model!=\"unknown\",endpoint!=\"other\"}, client_service)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(ollama_requests_total{job=\"ollama\",model!=\"unknown\",endpoint!=\"other\"}, client_service)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "vllm_model",
        "label": "vLLM 模型",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
        "query": {"query": "label_values({__name__=\"vllm:request_success_total\",job=\"vllm\"}, model_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values({__name__=\"vllm:request_success_total\",job=\"vllm\"}, model_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {"text": "All", "value": "$__all"},
        "options": []
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "模型流量监控",
  "uid": "model-traffic-overview",
  "version": 2,
  "panels": [
    {
      "id": 1,
      "title": "Ollama 状态",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "max(ollama_up{job=\"ollama\"})", "legendFormat": "状态", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "异常"}, "1": {"color": "green", "text": "正常"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 2,
      "title": "已安装模型",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum(ollama_model_available{job=\"ollama\",model=~\"$model\"})", "legendFormat": "模型", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 3,
      "title": "已加载模型",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum(ollama_model_loaded{job=\"ollama\",model=~\"$model\"})", "legendFormat": "加载中", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "请求速率",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum(rate(ollama_requests_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m]))", "legendFormat": "请求/秒", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "错误率",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "100 * sum(rate(ollama_errors_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m])) / clamp_min(sum(rate(ollama_requests_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m])), 0.001)", "legendFormat": "错误率", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 6,
      "title": "P95 调用耗时",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(ollama_request_duration_seconds_bucket{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"}[5m])))", "legendFormat": "P95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 7,
      "title": "每模型累计输入 Token",
      "type": "bargauge",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (model) (ollama_prompt_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"})", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto"}
    },
    {
      "id": 8,
      "title": "每模型累计输出 Token",
      "type": "bargauge",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (model) (ollama_generated_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"})", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto"}
    },
    {
      "id": 9,
      "title": "每模型累计总 Token",
      "type": "bargauge",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (model) (ollama_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"})", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto"}
    },
    {
      "id": 10,
      "title": "每模型 Token 速率",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model) (rate(ollama_prompt_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"}[5m]))", "legendFormat": "{{model}} 输入", "refId": "A"},
        {"expr": "sum by (model) (rate(ollama_generated_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"}[5m]))", "legendFormat": "{{model}} 输出", "refId": "B"},
        {"expr": "sum by (model) (rate(ollama_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"}[5m]))", "legendFormat": "{{model}} 总量", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11,
      "title": "每模型请求与错误",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model) (rate(ollama_requests_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m]))", "legendFormat": "{{model}} 请求", "refId": "A"},
        {"expr": "sum by (model) (rate(ollama_errors_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m]))", "legendFormat": "{{model}} 错误", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 12,
      "title": "每模型 P95 耗时",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, model) (rate(ollama_request_duration_seconds_bucket{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"}[5m])))", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 13,
      "title": "模型 VRAM 占用",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "ollama_model_vram_bytes{job=\"ollama\",model=~\"$model\"}", "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}, "overrides": []},
      "options": {"displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto"}
    },
    {
      "id": 14,
      "title": "模型状态与容量",
      "type": "table",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "ollama_model_status_info{job=\"ollama\",model=~\"$model\"}", "format": "table", "instant": true, "legendFormat": "{{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": [
        {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "__name__"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "job"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "instance"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "service"}, "properties": [{"id": "custom.hidden", "value": true}]},
        {"matcher": {"id": "byName", "options": "alert_email_group"}, "properties": [{"id": "displayName", "value": "告警组"}]},
        {"matcher": {"id": "byName", "options": "model"}, "properties": [{"id": "displayName", "value": "模型"}]},
        {"matcher": {"id": "byName", "options": "available"}, "properties": [{"id": "displayName", "value": "可用"}]},
        {"matcher": {"id": "byName", "options": "loaded"}, "properties": [{"id": "displayName", "value": "已加载"}]},
        {"matcher": {"id": "byName", "options": "size_bytes"}, "properties": [{"id": "displayName", "value": "模型大小(bytes)"}]},
        {"matcher": {"id": "byName", "options": "vram_bytes"}, "properties": [{"id": "displayName", "value": "VRAM(bytes)"}]},
        {"matcher": {"id": "byName", "options": "context_length"}, "properties": [{"id": "displayName", "value": "上下文长度"}]}
      ]},
      "options": {"cellHeight": "sm", "showHeader": true}
    },
    {
      "id": 15,
      "title": "服务-模型累计 Token",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (client_service, model) (ollama_tokens_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\"})", "format": "table", "instant": true, "legendFormat": "{{client_service}} / {{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"cellHeight": "sm", "showHeader": true}
    },
    {
      "id": 16,
      "title": "服务-模型请求速率",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum by (client_service, model) (rate(ollama_requests_total{job=\"ollama\",model=~\"$model\",client_service=~\"$client_service\",model!=\"unknown\",endpoint!=\"other\"}[5m]))", "legendFormat": "{{client_service}} / {{model}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 17,
      "title": "vLLM 流量",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
      "panels": []
    },
    {
      "id": 18,
      "title": "vLLM 状态",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 46},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "max(up{job=\"vllm\"}) or on() vector(0)", "legendFormat": "状态", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "异常"}, "1": {"color": "green", "text": "正常"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 19,
      "title": "vLLM 请求速率",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 46},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum(rate({__name__=\"vllm:request_success_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[5m])) or on() vector(0)", "legendFormat": "请求/秒", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 20,
      "title": "vLLM 等待请求",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 46},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum({__name__=\"vllm:num_requests_waiting\",job=\"vllm\",model_name=~\"$vllm_model\"}) or on() vector(0)", "legendFormat": "waiting", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 21,
      "title": "vLLM 输出 Token/s",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 46},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [{"expr": "sum(rate({__name__=\"vllm:generation_tokens_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[5m])) or on() vector(0)", "legendFormat": "token/s", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"}
    },
    {
      "id": 22,
      "title": "vLLM Token 流量",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 50},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model_name) (rate({__name__=\"vllm:prompt_tokens_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))", "legendFormat": "{{model_name}} 输入", "refId": "A"},
        {"expr": "sum by (model_name) (rate({__name__=\"vllm:generation_tokens_total\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval]))", "legendFormat": "{{model_name}} 输出", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 23,
      "title": "vLLM TTFT / E2E P95",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 8, "y": 50},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:time_to_first_token_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} TTFT", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, model_name) (rate({__name__=\"vllm:e2e_request_latency_seconds_bucket\",job=\"vllm\",model_name=~\"$vllm_model\"}[$__rate_interval])))", "legendFormat": "{{model_name}} E2E", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 24,
      "title": "vLLM 请求队列与运行中",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 50},
      "datasource": {"type": "prometheus", "uid": "prometheus-nextoffer"},
      "targets": [
        {"expr": "sum by (model_name) ({__name__=\"vllm:num_requests_running\",job=\"vllm\",model_name=~\"$vllm_model\"})", "legendFormat": "{{model_name}} running", "refId": "A"},
        {"expr": "sum by (model_name) ({__name__=\"vllm:num_requests_waiting\",job=\"vllm\",model_name=~\"$vllm_model\"})", "legendFormat": "{{model_name}} waiting", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    }
  ]
}
