{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "容器资源监控",
  "uid": "infrastructure-container-overview",
  "version": 1,
  "tags": [
    "infrastructure",
    "docker"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "环境",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "node",
        "label": "节点",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "运行容器",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "count(container_last_seen{job=\"cadvisor\",image!=\"\"})",
          "legendFormat": "容器",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "容器 CPU",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "topk(15, 100 * sum by (name, node) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\",image!=\"\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{node}} / {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "容器内存",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "topk(15, container_memory_working_set_bytes{job=\"cadvisor\",image!=\"\",environment=~\"$environment\"})",
          "legendFormat": "{{node}} / {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
