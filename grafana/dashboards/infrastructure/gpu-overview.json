{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "GPU 监控",
  "uid": "infrastructure-gpu-overview",
  "version": 1,
  "tags": [
    "infrastructure",
    "gpu"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "环境",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "node",
        "label": "节点",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "GPU 在线数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "count(host_gpu_info{environment=~\"$environment\",node=~\"$node\"})",
          "legendFormat": "GPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "GPU 利用率",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "host_gpu_utilization_percent{environment=~\"$environment\",node=~\"$node\"}",
          "legendFormat": "GPU {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "GPU 显存使用率",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "100 * host_gpu_memory_used_bytes{environment=~\"$environment\",node=~\"$node\"} / host_gpu_memory_total_bytes{environment=~\"$environment\",node=~\"$node\"}",
          "legendFormat": "GPU {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "GPU 温度",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "host_gpu_temperature_celsius{environment=~\"$environment\",node=~\"$node\"}",
          "legendFormat": "GPU {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
