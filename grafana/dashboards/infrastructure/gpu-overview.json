      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "host_gpu_memory_used_bytes{environment=~\"$environment\",node=~\"$node\"}",
          "legendFormat": "GPU {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
