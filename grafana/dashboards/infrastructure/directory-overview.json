{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "目录大小监控",
  "uid": "infrastructure-directory-overview",
  "version": 1,
  "tags": [
    "infrastructure",
    "disk",
    "directory-size"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "环境",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "node",
        "label": "节点",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "目录扫描延迟",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "(time() - host_directory_scan_timestamp_seconds{environment=~\"$environment\",node=~\"$node\"}) or on() vector(0)",
          "legendFormat": "失败",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "目录大小 Top 30",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "topk(30, host_directory_size_bytes{environment=~\"$environment\",node=~\"$node\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 3,
      "title": "目录大小趋势 Top 10",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "topk(10, host_directory_size_bytes{environment=~\"$environment\",node=~\"$node\"})",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
