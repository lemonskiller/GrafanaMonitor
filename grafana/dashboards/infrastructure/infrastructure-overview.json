  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "环境",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "node",
        "label": "节点",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "model",
        "label": "模型",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"training\",environment=~\"$environment\"}, model)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"training\",environment=~\"$environment\"}, model)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
