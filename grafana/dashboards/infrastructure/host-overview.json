{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 41,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "主机资源监控",
  "uid": "infrastructure-host-overview",
  "version": 1,
  "tags": [
    "infrastructure",
    "host"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "环境",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "node",
        "label": "节点",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-nextoffer"
        },
        "query": {
          "query": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(up{job=\"node\",environment=~\"$environment\"}, node)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "在线节点",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "sum(up{job=\"node\",environment=~\"$environment\"})",
          "legendFormat": "节点",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "主机 CPU 使用率",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "100 - 100 * avg by (node) (rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\",environment=~\"$environment\",node=~\"$node\"}[5m]))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "主机内存使用率",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"node\",environment=~\"$environment\",node=~\"$node\"} / node_memory_MemTotal_bytes{job=\"node\",environment=~\"$environment\",node=~\"$node\"})",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "主机网络吞吐",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-nextoffer"
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(node_network_receive_bytes_total{job=\"node\",device!~\"lo|veth.*|docker.*\",environment=~\"$environment\",node=~\"$node\"}[5m]))",
          "legendFormat": "{{node}} 接收",
          "refId": "A"
        },
        {
          "expr": "sum by (node) (rate(node_network_transmit_bytes_total{job=\"node\",device!~\"lo|veth.*|docker.*\",environment=~\"$environment\",node=~\"$node\"}[5m]))",
          "legendFormat": "{{node}} 发送",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
